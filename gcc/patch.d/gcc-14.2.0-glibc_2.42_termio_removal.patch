@@ -131,7 +131,7 @@
 
     enum NCC = 8;
 
-    struct termio
+    /* struct termio
     {
         ushort c_iflag;
         ushort c_oflag;
@@ -139,7 +139,7 @@
         ushort c_lflag;
         ubyte c_line;
         ubyte[NCC] c_cc;
-    }
+    } */
 
     enum TIOCM_LE = 0x001;
     enum TIOCM_DTR = 0x002;
